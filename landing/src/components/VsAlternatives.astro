---
// Replaces the former Differentiators feature cards. Promises a comparison
// in the section headline ("What Blind Bench does that others don't") and
// delivers one on the honest competitive axis: incumbents ship capable human
// review, but it is attribution-visible and the verdict rarely re-attaches to
// the artifact. Never claims competitors lack human review (false); the gap is
// BLIND + closed loop. Never claims we replace these tools — we pair with
// them — so the framing stays respectful.

const rows = [
  {
    tried: 'Annotation queues',
    examples: 'in Braintrust, LangSmith, Langfuse',
    gap: 'Capable tools &mdash; but every item shows the version and model. That anchors your highest-stakes call.',
    bb: 'Blind by construction. Provenance is stripped at the API boundary, so experts weigh the work, not the label.',
  },
  {
    tried: 'LLM-as-judge',
    examples: 'Promptfoo, plus your in-house graders',
    gap: 'Fast and cheap &mdash; but the judge drifts to its own phrasing, and nothing grades the judge.',
    bb: 'Your experts review the same runs blind, un-anchored by the judge&rsquo;s score &mdash; for calls that decide a release.',
  },
  {
    tried: 'Docs, sheets, threads',
    examples: 'the ad hoc review most teams run',
    gap: 'No blinding, no structure &mdash; the sharpest comment never re-attaches to its version.',
    bb: 'Structured and blind &mdash; the verdict routes back to the trace, a regression set, and the revision that cites it.',
  },
];
---

<section class="bg-muted/30 py-16 lg:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
        What Blind Bench does that others don&rsquo;t.
      </h2>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
        These tools already run human review. None hide the label from the
        reviewer or route the verdict back to the artifact. Blind Bench does
        both.
      </p>
    </div>

    <!-- Desktop: three-column comparison table.
         Mobile: stacked cards. -->
    <div class="reveal-scale mt-12">
      <!-- Desktop layout -->
      <div
        class="hidden overflow-hidden rounded-2xl border border-border bg-card lg:block"
      >
        <!-- Header row -->
        <div
          class="grid grid-cols-[1.1fr_1.4fr_1fr] border-b border-border bg-muted/40"
        >
          <div class="px-5 py-3 font-mono text-[11px] uppercase tracking-widest text-muted-foreground">
            In your stack today
          </div>
          <div class="px-5 py-3 font-mono text-[11px] uppercase tracking-widest text-muted-foreground">
            The gap
          </div>
          <div class="border-l border-border bg-primary/5 px-5 py-3 font-mono text-[11px] uppercase tracking-widest text-primary">
            Blind Bench
          </div>
        </div>

        <!-- Body rows -->
        {
          rows.map((r, i) => (
            <div
              class={`grid grid-cols-[1.1fr_1.4fr_1fr] ${i < rows.length - 1 ? 'border-b border-border' : ''}`}
            >
              <div class="px-5 py-5">
                <p class="text-sm font-semibold text-foreground" set:html={r.tried} />
                <p class="mt-1 text-xs text-muted-foreground">{r.examples}</p>
              </div>
              <div
                class="px-5 py-5 text-sm leading-relaxed text-muted-foreground"
                set:html={r.gap}
              />
              <div
                class="border-l border-border bg-primary/5 px-5 py-5 text-sm leading-relaxed text-foreground"
                set:html={r.bb}
              />
            </div>
          ))
        }
      </div>

      <!-- Mobile layout: stacked cards -->
      <div class="space-y-5 lg:hidden">
        {
          rows.map((r) => (
            <div class="overflow-hidden rounded-xl border border-border bg-card">
              <div class="border-b border-border bg-muted/40 px-4 py-3">
                <p class="text-sm font-semibold text-foreground" set:html={r.tried} />
                <p class="mt-0.5 text-xs text-muted-foreground">{r.examples}</p>
              </div>
              <dl class="divide-y divide-border">
                <div class="px-4 py-3">
                  <dt class="font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
                    The gap
                  </dt>
                  <dd
                    class="mt-1 text-sm leading-relaxed text-muted-foreground"
                    set:html={r.gap}
                  />
                </div>
                <div class="bg-primary/5 px-4 py-3">
                  <dt class="font-mono text-[10px] uppercase tracking-widest text-primary">
                    Blind Bench
                  </dt>
                  <dd
                    class="mt-1 text-sm leading-relaxed text-foreground"
                    set:html={r.bb}
                  />
                </div>
              </dl>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
