---
// Replaces the former Differentiators feature cards. Promises a comparison
// in the section headline ("What Blind Bench does that others don't") and
// now actually delivers one — named alternatives, named failure modes.

const rows = [
  {
    tried: 'Prompt management &amp; tracing',
    examples: 'Langfuse, PromptLayer, PostHog, Braintrust',
    gap: 'Built for developers. The reviewers whose judgment matters &mdash; PMs, legal, marketing &mdash; never open them, so feedback never reaches the prompt.',
    bb: 'Pairs with them and closes the loop: reviewer comments become the next prompt version.',
  },
  {
    tried: 'Eval platforms',
    examples: 'Promptfoo, LangSmith',
    gap: 'Reviewers see which variant is yours, and scores sit in a dashboard instead of driving the next edit.',
    bb: 'Blind by default. Every annotation maps to a concrete prompt change, cited to the comment.',
  },
  {
    tried: 'Google Docs / Slack',
    examples: 'or email threads',
    gap: 'No structure, no blinding, no path from a comment to a prompt change.',
    bb: 'Structured, blind, and traceable &mdash; every comment lands in the next iteration.',
  },
];
---

<section class="bg-muted/30 py-16 lg:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
        What Blind Bench does that others don&rsquo;t.
      </h2>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
        Other tools log prompts or collect scores. None of them close the loop.
        Blind Bench routes every reviewer comment back into the prompt &mdash;
        the next version is built from the feedback that drove it.
      </p>
    </div>

    <!-- Desktop: three-column comparison table.
         Mobile: stacked cards. -->
    <div class="reveal-scale mt-12">
      <!-- Desktop layout -->
      <div
        class="hidden overflow-hidden rounded-2xl border border-border bg-card lg:block"
      >
        <!-- Header row -->
        <div
          class="grid grid-cols-[1.1fr_1.4fr_1fr] border-b border-border bg-muted/40"
        >
          <div class="px-5 py-3 font-mono text-[11px] uppercase tracking-widest text-muted-foreground">
            You tried...
          </div>
          <div class="px-5 py-3 font-mono text-[11px] uppercase tracking-widest text-muted-foreground">
            What went wrong
          </div>
          <div class="border-l border-border bg-primary/5 px-5 py-3 font-mono text-[11px] uppercase tracking-widest text-primary">
            Blind Bench
          </div>
        </div>

        <!-- Body rows -->
        {
          rows.map((r, i) => (
            <div
              class={`grid grid-cols-[1.1fr_1.4fr_1fr] ${i < rows.length - 1 ? 'border-b border-border' : ''}`}
            >
              <div class="px-5 py-5">
                <p class="text-sm font-semibold text-foreground" set:html={r.tried} />
                <p class="mt-1 text-xs text-muted-foreground">{r.examples}</p>
              </div>
              <div
                class="px-5 py-5 text-sm leading-relaxed text-muted-foreground"
                set:html={r.gap}
              />
              <div
                class="border-l border-border bg-primary/5 px-5 py-5 text-sm leading-relaxed text-foreground"
                set:html={r.bb}
              />
            </div>
          ))
        }
      </div>

      <!-- Mobile layout: stacked cards -->
      <div class="space-y-5 lg:hidden">
        {
          rows.map((r) => (
            <div class="overflow-hidden rounded-xl border border-border bg-card">
              <div class="border-b border-border bg-muted/40 px-4 py-3">
                <p class="text-sm font-semibold text-foreground" set:html={r.tried} />
                <p class="mt-0.5 text-xs text-muted-foreground">{r.examples}</p>
              </div>
              <dl class="divide-y divide-border">
                <div class="px-4 py-3">
                  <dt class="font-mono text-[10px] uppercase tracking-widest text-muted-foreground">
                    What went wrong
                  </dt>
                  <dd
                    class="mt-1 text-sm leading-relaxed text-muted-foreground"
                    set:html={r.gap}
                  />
                </div>
                <div class="bg-primary/5 px-4 py-3">
                  <dt class="font-mono text-[10px] uppercase tracking-widest text-primary">
                    Blind Bench
                  </dt>
                  <dd
                    class="mt-1 text-sm leading-relaxed text-foreground"
                    set:html={r.bb}
                  />
                </div>
              </dl>
            </div>
          ))
        }
      </div>
    </div>

    <div
      class="reveal mx-auto mt-12 max-w-3xl rounded-2xl border border-border/60 bg-card/80 p-6 sm:p-8"
    >
      <div class="flex items-center gap-2">
        <span
          class="font-mono text-[10px] tracking-[0.18em] text-primary uppercase"
        >
          Soon
        </span>
        <span
          class="font-mono text-[10px] tracking-[0.18em] text-muted-foreground uppercase"
        >
          Bring your stack
        </span>
      </div>
      <h3
        class="mt-3 text-lg font-semibold tracking-tight text-foreground sm:text-xl"
      >
        Pairs with the tracing tools you already use.
      </h3>
      <p
        class="mt-2 text-sm leading-relaxed text-muted-foreground sm:text-base"
      >
        Pull runs from your tracing platform into a blind review, then push
        reviewer scores back. Blind Bench is the human layer &mdash; your
        stack stays the same.
      </p>
      <ul
        class="mt-5 flex flex-wrap gap-2"
        aria-label="Tracing platforms with planned integrations"
      >
        {
          ['Langfuse', 'Braintrust', 'PostHog', 'PromptLayer'].map((name) => (
            <li class="rounded-md border border-border bg-background/60 px-2.5 py-1 font-mono text-xs text-muted-foreground">
              {name}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
