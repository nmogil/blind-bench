---
// Trust strip: consolidates BYOK, blind-by-design, no-reviewer-accounts, and
// setup-time claims that were previously scattered (hero subline, section
// detail). One compact band directly above the closing CTA.
import EyeOff from '../icons/EyeOff.astro';
import Share from '../icons/Share.astro';
---

<section class="border-t border-border/50 py-12 lg:py-14">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <ul
      class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8"
    >
      <!-- BYOK -->
      <li class="reveal flex items-start gap-3">
        <div
          class="mt-0.5 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-md bg-primary/10 text-primary"
          aria-hidden="true"
        >
          <!-- Key icon (inline, lucide-style) -->
          <svg
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4" />
            <path d="m21 2-9.6 9.6" />
            <circle cx="7.5" cy="15.5" r="5.5" />
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-sm font-semibold text-foreground">BYOK</p>
          <p class="mt-1 text-xs leading-relaxed text-muted-foreground">
            Your OpenRouter key. Your compute. Your costs.
          </p>
        </div>
      </li>

      <!-- Blind by design -->
      <li class="reveal reveal-delay-2 flex items-start gap-3">
        <div
          class="mt-0.5 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-md bg-primary/10 text-primary"
          aria-hidden="true"
        >
          <EyeOff class="h-3.5 w-3.5" />
        </div>
        <div class="min-w-0">
          <p class="text-sm font-semibold text-foreground">Blind by design</p>
          <p class="mt-1 text-xs leading-relaxed text-muted-foreground">
            Metadata stripped at the API boundary &mdash; not the DOM.
          </p>
        </div>
      </li>

      <!-- No reviewer accounts -->
      <li class="reveal reveal-delay-3 flex items-start gap-3">
        <div
          class="mt-0.5 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-md bg-primary/10 text-primary"
          aria-hidden="true"
        >
          <Share class="h-3.5 w-3.5" />
        </div>
        <div class="min-w-0">
          <p class="text-sm font-semibold text-foreground">No reviewer accounts</p>
          <p class="mt-1 text-xs leading-relaxed text-muted-foreground">
            One link. They annotate. They close the tab.
          </p>
        </div>
      </li>

      <!-- Five-minute setup -->
      <li class="reveal reveal-delay-4 flex items-start gap-3">
        <div
          class="mt-0.5 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-md bg-primary/10 text-primary"
          aria-hidden="true"
        >
          <!-- Clock icon -->
          <svg
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
        </div>
        <div class="min-w-0">
          <p class="text-sm font-semibold text-foreground">Five-minute setup</p>
          <p class="mt-1 text-xs leading-relaxed text-muted-foreground">
            No credit card. No sales call.
          </p>
        </div>
      </li>
    </ul>
  </div>
</section>
