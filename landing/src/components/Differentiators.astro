---
import FeatureCard from './FeatureCard.astro';
import ArrowRight from '../icons/ArrowRight.astro';

const features = [
  {
    number: '01',
    category: 'COLLECTION',
    title: 'One link. No account.',
    description:
      'Share a link by Slack, email, or inside your product. Reviewers annotate in the browser.',
  },
  {
    number: '02',
    category: 'HONESTY',
    title: 'Blinded at the API, not the UI',
    description:
      'Reviewers never see the version, model, or author. Metadata is stripped from the response — not hidden in the DOM.',
  },
  {
    number: '03',
    category: 'APPLICATION',
    title: 'Annotations become prompt edits',
    description:
      'The optimizer rewrites your prompt from the feedback. Every change cites the comment it came from.',
  },
];

// Audience scenarios (merged from the old BuiltForTeams section). Rendered as
// a full-width row below the three feature cards so the grid stays balanced.
const audiences = [
  {
    title: 'Expert',
    description: 'Your lawyer or doctor annotates in five minutes.',
  },
  {
    title: 'Teammate',
    description: 'Evaluators see outputs, not prompts, not authors.',
  },
  {
    title: 'Customer',
    description: 'Embed evaluator links in your product or emails.',
  },
];
---

<section class="bg-muted/30 py-16 lg:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
        What Blind Bench does that others don't.
      </h2>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
        Prompt tools edit. Eval tools measure. Blind Bench gets real humans in
        the loop — and turns their feedback into edits.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8">
      {features.map((feature, i) => (
        <div class={`reveal reveal-delay-${i + 1}`}>
          <FeatureCard {...feature} />
        </div>
      ))}
    </div>

    <!-- Audience scenarios — full-width row below the features grid -->
    <div class="reveal mt-12 border-t border-border/60 pt-8 lg:mt-16 lg:pt-10">
      <p class="mb-5 text-center font-mono text-xs tracking-widest text-muted-foreground">
        YOUR REVIEWERS
      </p>
      <dl class="grid grid-cols-1 gap-6 sm:grid-cols-3 sm:gap-8">
        {audiences.map((a) => (
          <div class="text-center sm:text-left">
            <dt class="text-sm font-semibold text-foreground">{a.title}</dt>
            <dd class="mt-1 text-sm leading-relaxed text-muted-foreground">
              {a.description}
            </dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="reveal mt-10 text-center">
      <a
        href="https://app.blindbench.dev"
        class="inline-flex min-h-11 items-center gap-1.5 rounded-md px-3 py-2.5 text-sm font-medium text-primary transition-colors hover:text-primary/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
      >
        Start collecting feedback
        <ArrowRight class="h-3.5 w-3.5" />
      </a>
    </div>
  </div>
</section>
