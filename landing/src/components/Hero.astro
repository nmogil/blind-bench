---
import ArrowRight from '../icons/ArrowRight.astro';
import ArrowDown from '../icons/ArrowDown.astro';
import Grainient from './Grainient.astro';

const APP_URL = 'https://app.blindbench.dev';
---

<section class="relative -mt-14 overflow-hidden bg-neutral-950 pt-14 text-white">
  <Grainient
    class="hero-grainient"
    color1="#94a3b8"
    color2="#5227FF"
    color3="#000000"
    timeSpeed={0.25}
    zoom={0.9}
    contrast={1.5}
    opacity={1}
  />
  <!-- Static fallback for prefers-reduced-motion users -->
  <div
    aria-hidden="true"
    class="hero-grainient-fallback pointer-events-none absolute inset-0"
  ></div>
  <!-- Readability scrim: darkens the left column where text sits,
       preserves motion visibility on the right. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-gradient-to-r from-neutral-950/80 via-neutral-950/40 to-transparent"
  ></div>
  <!-- Mobile-only flat scrim. At phone widths the text column spans the
       full viewport, so the horizontal gradient's fade-out sits behind the
       copy. An extra flat layer keeps the headline legible on small screens. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-neutral-950/45 sm:hidden"
  ></div>
  <!-- Vertical polish: slight top vignette, stronger bottom fade for section seam -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-gradient-to-b from-neutral-950/30 via-transparent to-neutral-950/50"
  ></div>
  <div
    class="relative mx-auto max-w-5xl px-4 pt-24 pb-24 sm:px-6 lg:px-8 lg:pt-36 lg:pb-32 xl:max-w-7xl"
  >
    <div class="xl:flex xl:items-center xl:gap-12">
      <div class="hero-animate mx-auto max-w-3xl xl:mx-0 xl:min-w-0 xl:flex-1">
      <h1
        class="mt-6 text-[2rem] font-semibold leading-[1.12] tracking-tight text-white sm:text-[2.5rem] md:text-[3rem] lg:text-[3.25rem]"
      >
        Get blind review from{' '}
        <span class="hero-rotator" data-hero-rotator>
          <!-- Invisible sizer reserves width of the longest persona so the
               H1's line 1 never re-wraps as words rotate. Keep in sync with
               the ROLES array below. -->
          <span class="hero-rotator-sizer" aria-hidden="true">engineers</span>
          <!-- Screen readers get one stable headline; the rotating word is
               presentation-only. -->
          <span class="sr-only">experts</span>
          <span
            class="hero-rotator-clip"
            data-hero-rotator-active
            aria-hidden="true"
          ></span>
        </span>
        <br />
        before you trust the agent.
      </h1>

      <p
        class="mt-6 max-w-xl text-base leading-relaxed text-white/80 sm:text-lg"
      >
        Blind Bench hides each run&rsquo;s version, model, and harness from
        reviewers, so experts judge the work and you learn whether it improved.
      </p>

      <div
        class="mt-10 flex flex-col items-start gap-3 sm:flex-row sm:items-center sm:gap-4"
      >
        <a
          href={APP_URL}
          data-hero-cta="get_started"
          class="inline-flex items-center justify-center rounded-md bg-white px-6 py-3 text-sm font-semibold text-neutral-950 transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
        >
          Get started
          <ArrowRight class="ml-2 h-4 w-4" />
        </a>
        <a
          href="#demo-section"
          data-hero-cta="try_demo"
          class="inline-flex items-center justify-center rounded-md border border-white/30 bg-white/5 px-6 py-3 text-sm font-medium text-white backdrop-blur-sm transition-colors hover:bg-white/10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
        >
          Try a blind review
          <ArrowDown class="ml-1.5 h-4 w-4" />
        </a>
      </div>
      </div>

      <!-- Decorative product glimpse: a blind-review comparison card. Two
           outputs whose provenance (Version / Model) is visibly REDACTED —
           the redaction is the message — with one marked Preferred. Body
           text is skeleton bars, never readable fake content. Desktop only;
           the mobile hero is unchanged. Purely presentational: aria-hidden
           and pointer-events-none, sits on the bright right side of the
           gradient with its own dark-glass treatment. -->
      <div
        aria-hidden="true"
        class="pointer-events-none hidden xl:block xl:w-[340px] xl:shrink-0"
      >
        <div
          class="relative rounded-xl border border-white/10 bg-white/5 p-4 shadow-2xl shadow-black/40 backdrop-blur-md"
        >
          <!-- Card header -->
          <div class="mb-3 flex items-center justify-between">
            <span
              class="text-[11px] font-medium uppercase tracking-[0.14em] text-white/50"
              >Blind review</span
            >
            <span class="text-[11px] tracking-tight text-white/40"
              >Which is better?</span
            >
          </div>

          <!-- Output A -->
          <div class="rounded-lg border border-white/10 bg-white/[0.03] p-3">
            <div class="mb-2.5 flex items-center gap-2">
              <span
                class="flex h-5 w-5 items-center justify-center rounded bg-white/10 text-[11px] font-semibold text-white/80"
                >A</span
              >
              <span class="text-[11px] text-white/45">Output</span>
            </div>
            <!-- Redacted provenance: label + blurred block-character bar -->
            <div class="mb-3 flex flex-wrap gap-1.5">
              <span
                class="inline-flex items-center gap-1.5 rounded bg-white/5 px-1.5 py-0.5 text-[10px] text-white/40"
              >
                Version
                <span class="hero-redact font-mono text-white/30">██████</span>
              </span>
              <span
                class="inline-flex items-center gap-1.5 rounded bg-white/5 px-1.5 py-0.5 text-[10px] text-white/40"
              >
                Model
                <span class="hero-redact font-mono text-white/30">████████</span>
              </span>
            </div>
            <!-- Skeleton body -->
            <div class="space-y-1.5">
              <span class="block h-1.5 w-full rounded-full bg-white/10"></span>
              <span class="block h-1.5 w-[88%] rounded-full bg-white/10"></span>
              <span class="block h-1.5 w-[64%] rounded-full bg-white/10"></span>
            </div>
          </div>

          <!-- Output B — the preferred one -->
          <div
            class="relative mt-3 rounded-lg border border-violet-300/30 bg-violet-300/[0.06] p-3"
          >
            <span
              class="absolute -top-2.5 right-3 inline-flex items-center gap-1 rounded-full border border-violet-300/40 bg-neutral-950/85 px-2 py-0.5 text-[10px] font-medium text-violet-200 backdrop-blur-sm"
            >
              <svg
                viewBox="0 0 12 12"
                class="h-2.5 w-2.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M2.5 6.5 5 9l4.5-5.5" />
              </svg>
              Preferred
            </span>
            <div class="mb-2.5 flex items-center gap-2">
              <span
                class="flex h-5 w-5 items-center justify-center rounded bg-violet-300/20 text-[11px] font-semibold text-violet-100"
                >B</span
              >
              <span class="text-[11px] text-white/45">Output</span>
            </div>
            <div class="mb-3 flex flex-wrap gap-1.5">
              <span
                class="inline-flex items-center gap-1.5 rounded bg-white/5 px-1.5 py-0.5 text-[10px] text-white/40"
              >
                Version
                <span class="hero-redact font-mono text-white/30">███████</span>
              </span>
              <span
                class="inline-flex items-center gap-1.5 rounded bg-white/5 px-1.5 py-0.5 text-[10px] text-white/40"
              >
                Model
                <span class="hero-redact font-mono text-white/30">██████</span>
              </span>
            </div>
            <div class="space-y-1.5">
              <span
                class="block h-1.5 w-full rounded-full bg-violet-200/20"
              ></span>
              <span
                class="block h-1.5 w-[92%] rounded-full bg-violet-200/20"
              ></span>
              <span
                class="block h-1.5 w-[70%] rounded-full bg-violet-200/20"
              ></span>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Sentinel for the Nav.astro IntersectionObserver. When this element
         scrolls above the nav, the nav flips from transparent to solid. -->
    <div
      data-nav-sentinel
      aria-hidden="true"
      class="pointer-events-none absolute bottom-0 left-0 h-px w-px"
    ></div>
  </div>
</section>

<style>
  /* Fallback gradient for reduced-motion users — Grainient hides itself,
     this matches the sign-in page fallback. */
  .hero-grainient-fallback {
    background: linear-gradient(
      100deg,
      #94a3b8 0%,
      #5227ff 55%,
      #000000 100%
    );
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-grainient-fallback {
      opacity: 1;
    }
  }

  /* Rotating persona in the H1. A <br> in the markup parks this slot at the
     end of line 1, so the rotator's width changes don't push any sibling
     text around. */
  .hero-rotator {
    position: relative;
    display: inline-block;
    vertical-align: baseline;
    color: #ddd6fe;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-decoration-line: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.16em;
    text-decoration-color: rgba(221, 214, 254, 0.55);
  }

  /* Reserves layout width = longest persona word. Invisible but in-flow so
     the parent (and its underline) stays sized to the widest case. */
  .hero-rotator-sizer {
    display: inline-block;
    visibility: hidden;
    white-space: nowrap;
    pointer-events: none;
  }

  /* Animated chars overlay the sizer; absolute positioning keeps them out
     of normal flow so they don't double the rotator's width. */
  .hero-rotator-clip {
    position: absolute;
    inset: 0;
    display: inline-flex;
    overflow: hidden;
    white-space: nowrap;
    /* Extra vertical room so sliding chars + descenders don't clip at rest. */
    padding: 0.08em 0 0.12em;
    margin: -0.08em 0 -0.12em;
  }

  .hero-rotator-char {
    display: inline-block;
    will-change: transform, opacity;
  }

  /* Redacted provenance value. Blurred block characters read as suppressed
     data — the redaction is the message. Static; no motion to respect. */
  .hero-redact {
    display: inline-block;
    letter-spacing: -0.06em;
    filter: blur(1.5px);
    user-select: none;
  }
</style>

<script>
  import { trackLandingEvent } from '../lib/analytics';

  const ROTATOR_PERSONAS = ['engineers', 'legal', 'support', 'PMs', 'experts'] as const;

  function normalizePersona(value: string | undefined) {
    return ROTATOR_PERSONAS.find((persona) => persona === value) ?? 'unknown';
  }

  const rotator = document.querySelector<HTMLElement>('[data-hero-rotator]');
  const rotatorActive = rotator?.querySelector<HTMLElement>(
    '[data-hero-rotator-active]',
  );

  if (rotator && rotatorActive) {
    const ROLES = ROTATOR_PERSONAS;
    const DWELL_MS = 2000;
    const STAGGER_MS = 25; // matches React Bits staggerDuration 0.025
    const ENTER_MS = 420;
    const EXIT_MS = 320;
    const ENTER_EASING = 'cubic-bezier(0.22, 1, 0.36, 1)';
    const EXIT_EASING = 'cubic-bezier(0.7, 0, 0.84, 0)';
    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    let index = 0;
    let paused = false;
    let animating = false;

    // staggerFrom: 'last' — last char animates first, first char animates last.
    function delayFor(i: number, total: number): number {
      return (total - 1 - i) * STAGGER_MS;
    }

    function renderChars(text: string, animate: boolean): void {
      rotatorActive!.innerHTML = '';
      const chars = Array.from(text);
      chars.forEach((ch, i) => {
        const span = document.createElement('span');
        span.className = 'hero-rotator-char';
        span.textContent = ch === ' ' ? '\u00A0' : ch;
        rotatorActive!.appendChild(span);
        if (animate) {
          span.animate(
            [
              { transform: 'translateY(100%)', opacity: 0 },
              { transform: 'translateY(0)', opacity: 1 },
            ],
            {
              duration: ENTER_MS,
              delay: delayFor(i, chars.length),
              easing: ENTER_EASING,
              fill: 'backwards',
            },
          );
        }
      });
      rotator!.dataset.current = text;
    }

    async function exitCurrent(): Promise<void> {
      const chars = Array.from(
        rotatorActive!.querySelectorAll<HTMLElement>('.hero-rotator-char'),
      );
      if (!chars.length) return;
      const total = chars.length;
      await Promise.all(
        chars.map((el, i) => {
          const anim = el.animate(
            [
              { transform: 'translateY(0)', opacity: 1 },
              { transform: 'translateY(-120%)', opacity: 0 },
            ],
            {
              duration: EXIT_MS,
              delay: delayFor(i, total),
              easing: EXIT_EASING,
              fill: 'forwards',
            },
          );
          return anim.finished.catch(() => {});
        }),
      );
    }

    async function tick(): Promise<void> {
      if (animating) return;
      animating = true;
      await exitCurrent();
      index = (index + 1) % ROLES.length;
      renderChars(ROLES[index], true);
      animating = false;
    }

    // Initial paint — no entering animation on first load.
    renderChars(ROLES[0], false);

    if (!reducedMotion && ROLES.length > 1) {
      setInterval(() => {
        if (paused) return;
        void tick();
      }, DWELL_MS);

      // Hover pauses rotation so readers can dwell on a word.
      rotator.addEventListener('mouseenter', () => {
        paused = true;
      });
      rotator.addEventListener('mouseleave', () => {
        paused = false;
      });
    }
  }

  // Instrument CTA clicks with the persona that was visible at click time.
  // Passive learning — no A/B experiment setup needed — tells us which
  // persona correlates with conversion.
  document
    .querySelectorAll<HTMLElement>('[data-hero-cta]')
    .forEach((el) => {
      el.addEventListener('click', () => {
        const persona = normalizePersona(rotator?.dataset.current);
        const label = el.getAttribute('data-hero-cta');
        trackLandingEvent('hero_cta_click', {
          ctaLabel: label === 'try_demo' ? 'try_demo' : 'get_started',
          rotatorPersona: persona,
        });
      });
    });
</script>
