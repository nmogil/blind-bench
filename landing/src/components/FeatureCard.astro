---
interface Props {
  number: string;
  category: string;
  title: string;
  description: string;
}

const { number, category, title, description } = Astro.props;
---

<div class="group">
  <span class="block font-mono text-xs tracking-widest text-muted-foreground">
    {number} / {category}
  </span>
  <h3 class="mt-4 text-base font-semibold text-card-foreground sm:text-lg">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
    {description}
  </p>
</div>
