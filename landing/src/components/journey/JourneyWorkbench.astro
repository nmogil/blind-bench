---
import SetupPanel from './SetupPanel.astro';
import SharePanel from './SharePanel.astro';
import ApplyPanel from './ApplyPanel.astro';

const stages = ['Ingested', 'Blinded', 'Routed'];
---

<div
  class="journey-workbench overflow-hidden rounded-xl border border-border/90 bg-card shadow-[0_24px_80px_-48px_rgba(0,0,0,0.65)] ring-1 ring-foreground/4"
  data-journey-workbench
  data-active-step="0"
>
  <div class="flex items-center justify-between gap-4 border-b border-border/80 bg-background/45 px-4 py-3.5 sm:px-5">
    <div class="flex min-w-0 items-center gap-3">
      <svg width="20" height="20" viewBox="0 0 24 24" class="shrink-0 text-primary" aria-hidden="true">
        <rect x="0.75" y="0.75" width="22.5" height="22.5" rx="5.25" fill="none" stroke="currentColor" stroke-width="1.5" />
        <path d="M0.75 6A5.25 5.25 0 0 1 6 0.75h6v22.5H6A5.25 5.25 0 0 1 0.75 18Z" fill="currentColor" />
        <line x1="12" y1="0.75" x2="12" y2="23.25" stroke="currentColor" stroke-width="1" opacity="0.9" />
      </svg>
      <div class="min-w-0">
        <p class="truncate font-mono text-[10px] font-medium uppercase tracking-[0.16em] text-foreground/80">Review case · BB-1842</p>
        <p class="mt-0.5 truncate text-[10px] text-muted-foreground">Support agent · refund handling</p>
      </div>
    </div>
    <span class="shrink-0 rounded border border-border bg-card px-2 py-1 font-mono text-[9px] uppercase tracking-[0.12em] text-muted-foreground">Live artifact</span>
  </div>

  <ol class="grid grid-cols-3 border-b border-border/80 bg-background/30" aria-label="Review case progress">
    {stages.map((stage, index) => (
      <li
        class="workbench-stage relative flex items-center gap-2 border-r border-border/70 px-3 py-3 last:border-r-0 sm:px-4"
        data-workbench-stage={index}
      >
        <span class="stage-dot h-1.5 w-1.5 shrink-0 rounded-full bg-border"></span>
        <span class="truncate font-mono text-[9px] font-medium uppercase tracking-[0.13em] text-muted-foreground">{stage}</span>
      </li>
    ))}
  </ol>

  <div class="workbench-stack grid bg-card">
    <div
      class="workbench-state"
      data-workbench-state="0"
      data-motion-surface
      aria-hidden="false"
    >
      <SetupPanel />
    </div>
    <div
      class="workbench-state"
      data-workbench-state="1"
      data-motion-surface
      aria-hidden="true"
      inert
    >
      <SharePanel instance="desktop" />
    </div>
    <div
      class="workbench-state"
      data-workbench-state="2"
      data-motion-surface
      aria-hidden="true"
      inert
    >
      <ApplyPanel />
    </div>
  </div>
</div>

<style>
  .workbench-state {
    grid-area: 1 / 1;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px);
    transition: transform 380ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .journey-workbench[data-active-step='0'] .workbench-state[data-workbench-state='0'],
  .journey-workbench[data-active-step='1'] .workbench-state[data-workbench-state='1'],
  .journey-workbench[data-active-step='2'] .workbench-state[data-workbench-state='2'] {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .journey-workbench[data-active-step='0'] .workbench-stage[data-workbench-stage='0'],
  .journey-workbench[data-active-step='1'] .workbench-stage[data-workbench-stage='1'],
  .journey-workbench[data-active-step='2'] .workbench-stage[data-workbench-stage='2'] {
    background: color-mix(in oklch, var(--primary) 7%, transparent);
    color: var(--primary);
  }

  .journey-workbench[data-active-step='0'] .workbench-stage[data-workbench-stage='0'] span:last-child,
  .journey-workbench[data-active-step='1'] .workbench-stage[data-workbench-stage='1'] span:last-child,
  .journey-workbench[data-active-step='2'] .workbench-stage[data-workbench-stage='2'] span:last-child {
    color: var(--primary);
  }

  .journey-workbench[data-active-step='0'] .workbench-stage[data-workbench-stage='0'] .stage-dot,
  .journey-workbench[data-active-step='1'] .workbench-stage[data-workbench-stage='1'] .stage-dot,
  .journey-workbench[data-active-step='2'] .workbench-stage[data-workbench-stage='2'] .stage-dot {
    background: var(--primary);
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--primary) 12%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .workbench-state {
      transition: none;
    }
  }
</style>
