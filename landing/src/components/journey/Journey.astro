---
import JourneyWorkbench from './JourneyWorkbench.astro';
import SetupPanel from './SetupPanel.astro';
import SharePanel from './SharePanel.astro';
import ApplyPanel from './ApplyPanel.astro';

const steps = [
  {
    number: '01',
    eyebrow: 'Bring it in',
    title: 'Bring in what your agent did.',
    description:
      'Import Claude Code trajectories, gateway logs, or plain JSON — or run a prompt across models yourself. Your keys stay yours; Blind Bench never holds them.',
  },
  {
    number: '02',
    eyebrow: 'Review blind',
    title: 'Reviewers judge without the label.',
    description:
      'One link, no account. Candidate and control sit side by side, with the version, model, and harness hidden — so experts weigh the work, not the name.',
  },
  {
    number: '03',
    eyebrow: 'Route it back',
    title: 'Turn the verdict into the next run.',
    description:
      'Preferences roll up to standings. Comments re-attach to the trace and feed regression sets, training data, and prompt revisions — each citing the note it answers.',
  },
];
---

<section id="how-it-works" class="scroll-mt-16 py-20 lg:py-28">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <div class="reveal">
      <p class="font-mono text-[11px] font-medium uppercase tracking-[0.2em] text-primary">The closed review loop</p>
      <h2 class="mt-4 text-3xl font-semibold tracking-tight text-foreground sm:text-4xl md:text-5xl">
        From agent run to a verdict you trust.
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-muted-foreground sm:text-lg">
        Bring in what your agent produced, get blind judgment from the people who know the domain, and route their verdict back to where it changes the next run.
      </p>
    </div>
  </div>

  <div class="mx-auto mt-14 max-w-7xl px-4 sm:px-6 lg:mt-16 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(280px,0.72fr)_minmax(0,1.28fr)] lg:gap-12 xl:gap-16">
      <div class="space-y-20 lg:space-y-0">
        {steps.map((step, index) => (
          <article
            class="journey-step scroll-mt-24"
            data-journey-step={index}
            id={index === 1 ? 'demo-section' : undefined}
            aria-label={`Step ${index + 1}: ${step.eyebrow}`}
          >
            <div class="journey-copy lg:max-w-sm">
              <div class="mb-5 flex items-center gap-3">
                <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-primary/35 bg-primary/8 font-mono text-[10px] font-semibold text-primary">
                  {step.number}
                </span>
                <span class="font-mono text-[10px] font-medium uppercase tracking-[0.2em] text-primary">
                  {step.eyebrow}
                </span>
              </div>
              <h3 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">{step.title}</h3>
              <p class="mt-3 text-base leading-relaxed text-muted-foreground">{step.description}</p>
            </div>

            <div
              class="journey-mobile-scene mt-8 overflow-hidden rounded-xl border border-border/90 bg-card shadow-[0_20px_60px_-44px_rgba(0,0,0,0.7)] ring-1 ring-foreground/4 lg:hidden"
              data-mobile-journey-state={index}
            >
              {index === 0 && <SetupPanel />}
              {index === 1 && <SharePanel instance="mobile" compact />}
              {index === 2 && <ApplyPanel compact />}
            </div>
          </article>
        ))}
      </div>

      <div class="hidden lg:block">
        <div class="sticky top-24 flex h-[calc(100vh-7rem)] items-start pt-10">
          <div class="w-full">
            <JourneyWorkbench />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 1024px) {
    .journey-step {
      display: flex;
      min-height: 72vh;
      flex-direction: column;
      justify-content: center;
    }

    .journey-step:first-child {
      justify-content: flex-start;
      padding-top: clamp(2.5rem, 7vh, 4.5rem);
    }
  }

  @media (max-width: 389px) {
    .journey-mobile-scene {
      margin-inline: -0.25rem;
    }
  }
</style>

<script>
  type WorkbenchElement = HTMLElement & { dataset: { activeStep?: string } };

  const section = document.getElementById('how-it-works');
  const workbench = section?.querySelector<WorkbenchElement>('[data-journey-workbench]');
  const stepElements = section
    ? Array.from(section.querySelectorAll<HTMLElement>('[data-journey-step]'))
    : [];
  const stateElements = workbench
    ? Array.from(workbench.querySelectorAll<HTMLElement>('[data-workbench-state]'))
    : [];

  if (workbench && stepElements.length === 3 && stateElements.length === 3) {
    let activeStep = Number(workbench.dataset.activeStep ?? '0');

    const setActiveStep = (nextStep: number) => {
      if (nextStep === activeStep) return;
      activeStep = nextStep;
      workbench.dataset.activeStep = String(nextStep);

      for (const state of stateElements) {
        const isActive = state.dataset.workbenchState === String(nextStep);
        state.setAttribute('aria-hidden', String(!isActive));
        state.inert = !isActive;
      }
    };

    let frameRequested = false;
    const updateActiveStep = () => {
      frameRequested = false;
      const viewportCenter = window.innerHeight / 2;
      let closestStep = 0;
      let closestDistance = Number.POSITIVE_INFINITY;

      for (const [index, stepElement] of stepElements.entries()) {
        const rect = stepElement.getBoundingClientRect();
        const distance = Math.abs(rect.top + rect.height / 2 - viewportCenter);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestStep = index;
        }
      }

      const currentStep = stepElements[activeStep];
      if (!currentStep || closestStep === activeStep) return;
      const currentRect = currentStep.getBoundingClientRect();
      const currentDistance = Math.abs(
        currentRect.top + currentRect.height / 2 - viewportCenter,
      );
      const switchThreshold = window.innerHeight * 0.08;
      if (currentDistance - closestDistance > switchThreshold) {
        setActiveStep(closestStep);
      }
    };

    const requestUpdate = () => {
      if (frameRequested) return;
      frameRequested = true;
      requestAnimationFrame(updateActiveStep);
    };

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
    updateActiveStep();
  }
</script>
