---
import JourneyDiagram from './JourneyDiagram.astro';
import SetupPanel from './SetupPanel.astro';
import SharePanel from './SharePanel.astro';
import ApplyPanel from './ApplyPanel.astro';

const steps = [
  {
    number: '01',
    eyebrow: 'Set up',
    title: 'Draft a prompt, pick the models.',
    description:
      'Write your system message, mark the variables, and choose a few models or temperatures to compare side-by-side.',
  },
  {
    number: '02',
    eyebrow: 'Share',
    title: 'Send one link. No login.',
    description:
      'Reviewers see outputs blind — no model names, no version numbers — and highlight the lines they like or hate right in the browser.',
  },
  {
    number: '03',
    eyebrow: 'Apply',
    title: 'Turn feedback into prompt edits.',
    description:
      'The optimizer reads every annotation and proposes a new version, with each change cited to the comment that motivated it.',
  },
];
---

<section id="how-it-works" class="scroll-mt-16 py-20 lg:py-28">
  <!-- Section header (narrower for readability) -->
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <div class="reveal">
      <h2
        class="text-3xl font-semibold tracking-tight text-foreground sm:text-4xl md:text-5xl"
      >
        From prompt to production.
        <span class="block font-semibold text-muted-foreground/60">
          Three steps, one link.
        </span>
      </h2>
      <p class="mt-5 text-base leading-relaxed text-muted-foreground sm:text-lg">
        Draft, get blind reviewer feedback, and apply concrete prompt edits —
        without leaving a tab open for your reviewers.
      </p>
    </div>
  </div>

  <!-- Sticky split: diagram (left) + step blocks (right) — wider container -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="journey-scroller mt-14 lg:mt-20">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[420px_minmax(0,1fr)] lg:gap-10 xl:gap-16">
        <!-- Left: sticky diagram (desktop) / inline (mobile) -->
        <div class="journey-sticky-col">
          <div class="journey-sticky-inner lg:sticky lg:top-24 lg:flex lg:h-[calc(100vh-7rem)] lg:items-center">
            <JourneyDiagram default={0} />
          </div>
        </div>

        <!-- Right: stacked step blocks -->
        <div class="space-y-24 lg:space-y-32">
          {
            steps.map((s, i) => (
              <article
                class="journey-step"
                data-journey-step={i}
                aria-label={`Step ${s.number}: ${s.eyebrow}`}
              >
                <div class="mb-6 flex items-center gap-3">
                  <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-primary/40 bg-primary/10 font-mono text-[11px] font-semibold text-primary">
                    {i + 1}
                  </span>
                  <span class="font-mono text-[11px] font-medium uppercase tracking-[0.2em] text-primary">
                    {s.eyebrow}
                  </span>
                </div>
                <h3 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
                  {s.title}
                </h3>
                <p class="mt-3 max-w-xl text-base leading-relaxed text-muted-foreground">
                  {s.description}
                </p>

                <div class="mt-8">
                  {i === 0 && <SetupPanel />}
                  {i === 1 && <SharePanel />}
                  {i === 2 && <ApplyPanel />}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Mobile (no sticky): center the diagram naturally above the first step. */
  @media (max-width: 1023.98px) {
    .journey-sticky-inner {
      padding-bottom: 1.5rem;
    }
  }

  /* On desktop, give each step block enough vertical room so the sticky
     diagram has scroll distance to dwell on each. The min-height of the
     last block is reduced so the section ends near the bottom of its panel
     rather than leaving empty space below the final step. */
  @media (min-width: 1024px) {
    .journey-step {
      min-height: 80vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .journey-step:last-child {
      min-height: 0;
    }
  }
</style>

<script>
  type DiagramEl = HTMLElement & { dataset: { activeStep?: string } };

  const section = document.getElementById('how-it-works');
  if (section) {
    const diagram = section.querySelector<DiagramEl>('[data-journey-diagram]');
    const stepEls = Array.from(
      section.querySelectorAll<HTMLElement>('[data-journey-step]'),
    );

    if (diagram && stepEls.length) {
      let active = Number(diagram.dataset.activeStep || '0');

      const setActive = (i: number) => {
        if (i === active) return;
        active = i;
        diagram.dataset.activeStep = String(i);
      };

      // Pick the step whose center is closest to the viewport's vertical center.
      // Runs on scroll/resize; rAF-throttled to keep it cheap.
      let ticking = false;
      const update = () => {
        ticking = false;
        const viewportCenter = window.innerHeight / 2;
        let best = 0;
        let bestDist = Infinity;
        for (let i = 0; i < stepEls.length; i++) {
          const r = stepEls[i].getBoundingClientRect();
          const center = r.top + r.height / 2;
          const dist = Math.abs(center - viewportCenter);
          if (dist < bestDist) {
            bestDist = dist;
            best = i;
          }
        }
        setActive(best);
      };

      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(update);
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      update();

      // Hash support: #demo-section (used by Nav + CtaFooter) — anchor
      // scroll still works because <SharePanel> keeps id="demo-section".
      // The scroll listener will pick up the resulting position and set
      // the diagram to step 2 automatically.
    }
  }
</script>
