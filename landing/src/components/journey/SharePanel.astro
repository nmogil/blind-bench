---
import User from '../../icons/User.astro';

interface Props {
  instance: 'desktop' | 'mobile';
  compact?: boolean;
}

const { instance, compact = false } = Astro.props;
const convexSiteUrl = import.meta.env.PUBLIC_CONVEX_SITE_URL || '';
---

<div
  class:list={['share-state', compact && 'share-state-compact']}
  data-demo-instance={instance}
  data-convex-url={convexSiteUrl}
>
  <div class="border-b border-border/80 px-4 py-3 sm:px-5">
    <div class="flex items-center justify-between gap-3">
      <span class="truncate font-mono text-[10px] font-medium uppercase tracking-[0.16em] text-foreground/70">Identity removed</span>
      <span class="font-mono text-[9px] uppercase tracking-[0.14em] text-primary">Blind mode</span>
    </div>

    <div class="mt-3 grid grid-cols-2 gap-2" aria-hidden="true">
      <div class="identity-route relative overflow-hidden rounded-md border border-border bg-background/45 px-3 py-2">
        <span class="source-identity block truncate font-mono text-[9px] text-muted-foreground">Claude Haiku · control</span>
        <span class="blind-identity absolute inset-0 flex items-center px-3 font-mono text-[10px] font-semibold text-primary">Output A</span>
        <span class="blind-shutter absolute inset-y-0 left-0 w-full origin-left bg-primary"></span>
      </div>
      <div class="identity-route relative overflow-hidden rounded-md border border-border bg-background/45 px-3 py-2">
        <span class="source-identity block truncate font-mono text-[9px] text-muted-foreground">GPT-4o · candidate</span>
        <span class="blind-identity absolute inset-0 flex items-center px-3 font-mono text-[10px] font-semibold text-primary">Output B</span>
        <span class="blind-shutter absolute inset-y-0 left-0 w-full origin-left bg-primary"></span>
      </div>
    </div>
  </div>

  <div class="border-b border-border/80 bg-background/30 px-4 py-3 sm:px-5">
    <div class="flex items-start gap-3">
      <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-amber/12">
        <User class="h-3.5 w-3.5 text-amber" />
      </span>
      <div class="min-w-0">
        <p class="font-mono text-[9px] uppercase tracking-[0.14em] text-muted-foreground">Test case · duplicate charge</p>
        <p class="mt-1 text-[11px] leading-relaxed text-foreground/80 sm:text-xs">
          “I was charged $49 twice this month. I’ve been a customer for two years—can you sort this out?”
        </p>
      </div>
    </div>
  </div>

  <div class="grid gap-px bg-border/80 sm:grid-cols-2" data-demo-outputs>
    <button
      type="button"
      class="demo-choice bg-card p-4 text-left transition-[background-color,opacity,box-shadow] duration-300 hover:bg-muted/25 focus-visible:z-10 focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-ring sm:p-5"
      data-choice="A"
      aria-pressed="false"
    >
      <div class="mb-3 flex items-center justify-between gap-2">
        <div class="flex items-center gap-2">
          <span class="demo-blind-label inline-flex h-6 w-6 items-center justify-center rounded bg-primary/12 font-mono text-[10px] font-semibold text-primary">A</span>
          <span class="demo-blind-tag font-mono text-[9px] uppercase tracking-[0.13em] text-muted-foreground">Output</span>
          <span class="demo-real-label hidden font-mono text-[9px] font-medium text-primary">Control</span>
        </div>
        <span class="choice-check text-[10px] text-primary opacity-0" aria-hidden="true">Selected</span>
      </div>
      <p class="text-[11px] leading-[1.65] text-foreground/78 sm:text-xs">
        I’m sorry about the double charge. I’ve issued a refund for the duplicate $49 payment; it should appear in 3–5 business days. Reply here if it doesn’t and I’ll escalate it.
      </p>
    </button>

    <button
      type="button"
      class="demo-choice bg-card p-4 text-left transition-[background-color,opacity,box-shadow] duration-300 hover:bg-muted/25 focus-visible:z-10 focus-visible:outline-2 focus-visible:outline-offset-[-2px] focus-visible:outline-ring sm:p-5"
      data-choice="B"
      aria-pressed="false"
    >
      <div class="mb-3 flex items-center justify-between gap-2">
        <div class="flex items-center gap-2">
          <span class="demo-blind-label inline-flex h-6 w-6 items-center justify-center rounded bg-primary/12 font-mono text-[10px] font-semibold text-primary">B</span>
          <span class="demo-blind-tag font-mono text-[9px] uppercase tracking-[0.13em] text-muted-foreground">Output</span>
          <span class="demo-real-label hidden font-mono text-[9px] font-medium text-primary">Candidate</span>
        </div>
        <span class="choice-check text-[10px] text-primary opacity-0" aria-hidden="true">Selected</span>
      </div>
      <p class="text-[11px] leading-[1.65] text-foreground/78 sm:text-xs">
        Thank you for reaching out. I confirmed the second $49 charge was an error and initiated a full refund. It will be reflected within 3–5 business days. Your account has also been flagged.
      </p>
    </button>
  </div>

  <div class="flex min-h-12 items-center justify-between gap-3 border-t border-border/80 bg-background/35 px-4 py-3 sm:px-5">
    <span class="text-[10px] text-muted-foreground" data-demo-status>2 outputs · identities sealed</span>
    <span class="text-right text-[10px] font-medium text-primary" data-demo-prompt>Choose the reply you’d send</span>
    <div class="text-right" data-demo-reveal role="status" aria-live="polite" aria-atomic="true" hidden>
      <p class="text-[10px] font-medium text-foreground" data-reveal-headline></p>
      <p class="mt-0.5 text-[10px] text-muted-foreground" data-reveal-stats></p>
    </div>
  </div>
</div>

<style>
  .share-state {
    display: flex;
    min-height: 100%;
    flex-direction: column;
  }

  .share-state [data-demo-outputs] {
    flex: 1;
  }

  .source-identity,
  .blind-identity,
  .blind-shutter {
    transition:
      opacity 180ms ease,
      transform 360ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .blind-identity {
    opacity: 0;
  }

  .blind-shutter {
    transform: scaleX(0);
  }

  :global(.journey-workbench[data-active-step='1']) .blind-shutter {
    animation: blind-pass 560ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  :global(.journey-workbench[data-active-step='1']) .source-identity {
    opacity: 0;
    transition-delay: 250ms;
  }

  :global(.journey-workbench[data-active-step='1']) .blind-identity {
    opacity: 1;
    transition-delay: 280ms;
  }

  .share-state-compact .source-identity,
  .share-state-compact .blind-shutter {
    opacity: 0;
  }

  .share-state-compact .blind-identity {
    opacity: 1;
  }

  @keyframes blind-pass {
    0% { transform: scaleX(0); transform-origin: left; }
    48% { transform: scaleX(1); transform-origin: left; }
    52% { transform: scaleX(1); transform-origin: right; }
    100% { transform: scaleX(0); transform-origin: right; }
  }

  .demo-choice.selected {
    background: color-mix(in oklch, var(--primary) 7%, var(--card));
    box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--primary) 65%, transparent);
  }

  .demo-choice.selected .choice-check {
    opacity: 1;
  }

  .demo-choice.dimmed {
    opacity: 0.42;
  }

  .demo-choice.voted {
    cursor: default;
  }

  .demo-choice.revealed .demo-blind-label,
  .demo-choice.revealed .demo-blind-tag {
    display: none;
  }

  .demo-choice.revealed .demo-real-label {
    display: inline;
  }

  @media (prefers-reduced-motion: reduce) {
    .source-identity,
    .blind-identity,
    .blind-shutter,
    .demo-choice {
      animation: none !important;
      transition: none !important;
    }

    :global(.journey-workbench[data-active-step='1']) .blind-shutter {
      opacity: 0;
    }
  }
</style>

<script>
  type VoteChoice = 'A' | 'B';
  type VoteStats = {
    readonly totalVotes: number;
    readonly percentA: number;
    readonly percentB: number;
  };

  const storageKey = 'bb-demo-vote';

  const isVoteChoice = (value: string | null): value is VoteChoice =>
    value === 'A' || value === 'B';

  const readStoredVote = (): VoteChoice | null => {
    try {
      const value = localStorage.getItem(storageKey);
      return isVoteChoice(value) ? value : null;
    } catch {
      return null;
    }
  };

  const storeVote = (choice: VoteChoice) => {
    try {
      localStorage.setItem(storageKey, choice);
    } catch {
      // Storage is optional; the in-page vote still works without it.
    }
  };

  const parseVoteStats = (value: unknown): VoteStats | null => {
    if (typeof value !== 'object' || value === null) return null;
    const totalVotes: unknown = Reflect.get(value, 'totalVotes');
    const percentA: unknown = Reflect.get(value, 'percentA');
    const percentB: unknown = Reflect.get(value, 'percentB');
    if (
      typeof totalVotes !== 'number' ||
      typeof percentA !== 'number' ||
      typeof percentB !== 'number'
    ) return null;
    return { totalVotes, percentA, percentB };
  };

  document.querySelectorAll<HTMLElement>('[data-demo-instance]').forEach((section) => {
    if (section.dataset.initialized === 'true') return;
    section.dataset.initialized = 'true';

    const choices = Array.from(section.querySelectorAll<HTMLButtonElement>('[data-choice]'));
    const reveal = section.querySelector<HTMLElement>('[data-demo-reveal]');
    const revealHeadline = section.querySelector<HTMLElement>('[data-reveal-headline]');
    const revealStats = section.querySelector<HTMLElement>('[data-reveal-stats]');
    const prompt = section.querySelector<HTMLElement>('[data-demo-prompt]');
    const status = section.querySelector<HTMLElement>('[data-demo-status]');
    const convexUrl = section.dataset.convexUrl || '';
    let hasVoted = false;

    const renderStats = (choice: VoteChoice, stats: VoteStats) => {
      if (!revealStats || stats.totalVotes <= 1) return;
      const percent = choice === 'A' ? stats.percentA : stats.percentB;
      revealStats.textContent = `${percent}% agreed · ${stats.totalVotes.toLocaleString()} votes`;
    };

    const loadStats = async (choice: VoteChoice) => {
      if (!convexUrl) return;
      try {
        const response = await fetch(`${convexUrl}/api/demo-stats`);
        const value: unknown = await response.json();
        const stats = parseVoteStats(value);
        if (stats) renderStats(choice, stats);
      } catch {
        // Aggregate stats are optional; the local vote remains complete.
      }
    };

    const showReveal = (choice: VoteChoice) => {
      for (const button of choices) {
        const buttonChoice = button.dataset.choice;
        const selected = buttonChoice === choice;
        button.classList.add('voted', 'revealed');
        button.classList.toggle('selected', selected);
        button.classList.toggle('dimmed', !selected);
        button.setAttribute('aria-pressed', String(selected));
      }
      if (prompt) prompt.hidden = true;
      if (status) status.textContent = 'Verdict recorded · identities revealed';
      if (reveal) reveal.hidden = false;
      requestAnimationFrame(() => {
        if (revealHeadline) {
          revealHeadline.textContent =
            choice === 'A' ? 'Control selected' : 'Candidate selected';
        }
      });
    };

    const submitVote = async (choice: VoteChoice) => {
      if (hasVoted) return;
      const storedVote = readStoredVote();
      if (storedVote) {
        hasVoted = true;
        showReveal(storedVote);
        return;
      }
      hasVoted = true;
      storeVote(choice);
      showReveal(choice);

      if (!convexUrl) return;
      try {
        const response = await fetch(`${convexUrl}/api/demo-vote`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ choice }),
        });
        const value: unknown = await response.json();
        const stats = parseVoteStats(value);
        if (stats) renderStats(choice, stats);
      } catch {
        // The illustrative vote still succeeds when aggregate stats are unavailable.
      }
    };

    for (const button of choices) {
      button.addEventListener('click', () => {
        const choice = button.dataset.choice || null;
        if (isVoteChoice(choice)) void submitVote(choice);
      });
    }

    const previousVote = readStoredVote();
    if (previousVote) {
      hasVoted = true;
      showReveal(previousVote);
      void loadStats(previousVote);
    }
  });
</script>
