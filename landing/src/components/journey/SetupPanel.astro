---
import Play from '../../icons/Play.astro';

---

<div class="setup-state">
  <div class="flex items-center justify-between gap-4 border-b border-border/80 px-4 py-3 sm:px-5">
    <span class="truncate font-mono text-[10px] font-medium uppercase tracking-[0.16em] text-foreground/70">Trace received</span>
    <span class="flex items-center gap-1.5 font-mono text-[9px] uppercase tracking-[0.14em] text-muted-foreground">
      <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
      Ready
    </span>
  </div>

  <div class="grid gap-px bg-border/80 sm:grid-cols-[0.9fr_1.1fr]">
    <div class="bg-card p-4 sm:p-5">
      <p class="font-mono text-[9px] font-medium uppercase tracking-[0.16em] text-muted-foreground">Source artifact</p>
      <div class="mt-3 flex items-center gap-3 rounded-lg border border-border bg-background/45 p-3">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-primary/25 bg-primary/10 font-mono text-[10px] font-semibold text-primary">JSONL</span>
        <div class="min-w-0">
          <p class="truncate font-mono text-xs text-foreground/90">support-agent-run.jsonl</p>
          <p class="mt-1 text-[10px] text-muted-foreground">24 turns · 3 test cases</p>
        </div>
      </div>
      <div class="mt-4 space-y-2.5" aria-label="Import checks">
        <div class="flex items-center justify-between text-[11px]">
          <span class="text-muted-foreground">Trajectory parsed</span>
          <span class="font-mono text-foreground/70">24/24</span>
        </div>
        <div class="h-px bg-border/80"><div class="h-px w-full bg-primary/70"></div></div>
        <div class="flex items-center justify-between text-[11px]">
          <span class="text-muted-foreground">Sensitive fields</span>
          <span class="font-mono text-foreground/70">isolated</span>
        </div>
      </div>
    </div>

    <div class="bg-card p-4 sm:p-5">
      <div class="flex items-center justify-between gap-3">
        <p class="font-mono text-[9px] font-medium uppercase tracking-[0.16em] text-muted-foreground">Review batch</p>
        <span class="text-[10px] text-muted-foreground">hidden from reviewers</span>
      </div>
      <div class="mt-3 space-y-2">
        <div class="flex items-center gap-3 rounded-lg border border-border bg-background/45 p-3">
          <span class="inline-flex h-6 w-6 items-center justify-center rounded bg-muted font-mono text-[10px] font-semibold text-foreground/80">A</span>
          <div class="min-w-0 flex-1">
            <p class="text-xs font-medium text-foreground">Control</p>
            <p class="mt-0.5 truncate text-[10px] text-muted-foreground">live support agent</p>
          </div>
          <span class="font-mono text-[9px] text-muted-foreground">v3</span>
        </div>
        <div class="flex items-center gap-3 rounded-lg border border-primary/25 bg-primary/5 p-3">
          <span class="inline-flex h-6 w-6 items-center justify-center rounded bg-primary/12 font-mono text-[10px] font-semibold text-primary">B</span>
          <div class="min-w-0 flex-1">
            <p class="text-xs font-medium text-foreground">Candidate</p>
            <p class="mt-0.5 truncate text-[10px] text-muted-foreground">new agent revision</p>
          </div>
          <span class="font-mono text-[9px] text-primary">v4</span>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-border/80 bg-background/35 px-4 py-3.5 sm:px-5">
    <div class="flex items-start gap-3">
      <span class="mt-0.5 font-mono text-[9px] uppercase tracking-[0.14em] text-muted-foreground">Prompt</span>
      <p class="min-w-0 font-mono text-[11px] leading-relaxed text-foreground/75 sm:text-xs">
        You are a customer support agent. <span class="setup-highlight">Be friendly and professional.</span> Resolve the issue clearly.
      </p>
    </div>
    <div class="mt-3 flex items-center justify-between border-t border-border/70 pt-3">
      <span class="text-[10px] text-muted-foreground">Case BB-1842 · BYOK</span>
      <span class="inline-flex items-center gap-1.5 rounded-md bg-primary px-3 py-1.5 text-[10px] font-medium text-primary-foreground">
        <Play class="h-3 w-3" />
        Prepare review
      </span>
    </div>
  </div>
</div>

<style>
  .setup-highlight {
    border-radius: 3px;
    background: color-mix(in oklch, var(--primary) 15%, transparent);
    color: var(--primary);
    padding: 0.08em 0.22em;
  }
</style>
