---
import ArrowRight from '../../icons/ArrowRight.astro';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class:list={['apply-state', compact && 'apply-state-compact']}>
  <div class="flex items-center justify-between gap-4 border-b border-border/80 px-4 py-3 sm:px-5">
    <span class="truncate font-mono text-[10px] font-medium uppercase tracking-[0.16em] text-foreground/70">Verdict routed</span>
    <span class="font-mono text-[9px] uppercase tracking-[0.14em] text-primary">Loop closed</span>
  </div>

  <div class="border-b border-border/80 bg-background/30 px-4 py-3 sm:px-5">
    <div class="grid gap-3 sm:grid-cols-[auto_1fr_auto] sm:items-center">
      <div>
        <p class="font-mono text-[9px] uppercase tracking-[0.14em] text-muted-foreground">Blind verdict</p>
        <p class="mt-1 text-sm font-semibold text-foreground">Candidate +12%</p>
      </div>
      <div class="hidden h-px bg-border sm:block"><div class="verdict-line h-px bg-primary"></div></div>
      <p class="max-w-[230px] text-[10px] leading-relaxed text-muted-foreground sm:text-right">
        7 of 9 reviewers flagged the same tone issue.
      </p>
    </div>
  </div>

  <div class="grid gap-px bg-border/80 sm:grid-cols-[0.92fr_1.08fr]">
    <div class="bg-card p-4 sm:p-5">
      <div class="flex items-center justify-between gap-3">
        <p class="font-mono text-[9px] font-medium uppercase tracking-[0.16em] text-muted-foreground">Evidence attached</p>
        <span class="font-mono text-[9px] text-muted-foreground">2 notes</span>
      </div>
      <div class="mt-3 space-y-2.5">
        <div class="annotation-card rounded-lg border border-border bg-background/45 p-3">
          <div class="flex items-center gap-2">
            <span class="inline-flex h-5 w-5 items-center justify-center rounded bg-primary/12 font-mono text-[9px] font-semibold text-primary">A</span>
            <span class="font-mono text-[9px] uppercase tracking-[0.12em] text-muted-foreground">Tone</span>
          </div>
          <p class="mt-2 text-[11px] leading-relaxed text-foreground/78">“Reads like a corporate form letter.”</p>
        </div>
        <div class="annotation-card annotation-card-delay rounded-lg border border-border bg-background/45 p-3">
          <div class="flex items-center gap-2">
            <span class="inline-flex h-5 w-5 items-center justify-center rounded bg-primary/12 font-mono text-[9px] font-semibold text-primary">B</span>
            <span class="font-mono text-[9px] uppercase tracking-[0.12em] text-muted-foreground">Specificity</span>
          </div>
          <p class="mt-2 text-[11px] leading-relaxed text-foreground/78">“‘I understand your concern’ is filler.”</p>
        </div>
      </div>
    </div>

    <div class="bg-card p-4 sm:p-5">
      <div class="flex items-center justify-between gap-3">
        <p class="font-mono text-[9px] font-medium uppercase tracking-[0.16em] text-muted-foreground">Prompt revision</p>
        <span class="font-mono text-[9px] text-primary">v3 → v4</span>
      </div>
      <div class="mt-3 rounded-lg border border-border bg-background/45 p-3.5 font-mono text-[11px] leading-[1.7] text-foreground/75">
        <p>
          You are a <span class="diff-old">helpful</span> customer support agent.
        </p>
        <p class="mt-2">
          <span class="diff-new">Write like a helpful coworker, not a corporate robot. Avoid form-letter openers and get to the point warmly.</span>
        </p>
      </div>
      <div class="mt-3 flex items-center gap-2 text-[10px] text-primary">
        <span>Reviewer evidence applied</span>
        <ArrowRight class="h-3 w-3" />
      </div>
    </div>
  </div>

  <div class="flex items-center justify-between gap-3 border-t border-border/80 bg-background/35 px-4 py-3 sm:px-5">
    <span class="text-[10px] text-muted-foreground">Case BB-1842 · audit trail preserved</span>
    <span class="inline-flex items-center gap-1.5 rounded-md border border-primary/25 bg-primary/8 px-2.5 py-1.5 font-mono text-[9px] font-medium uppercase tracking-[0.12em] text-primary">
      <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
      Next run ready
    </span>
  </div>
</div>

<style>
  .diff-old {
    border-radius: 3px;
    background: color-mix(in oklch, var(--step-3) 15%, transparent);
    color: var(--step-3);
    padding: 0.08em 0.2em;
    text-decoration: line-through;
    text-decoration-thickness: 1px;
  }

  .diff-new {
    border-radius: 3px;
    background: color-mix(in oklch, var(--primary) 15%, transparent);
    color: var(--primary);
    padding: 0.08em 0.2em;
  }

  .verdict-line {
    transform: scaleX(0);
    transform-origin: left;
  }

  .annotation-card {
    opacity: 0;
    transform: translateX(-10px);
  }

  :global(.journey-workbench[data-active-step='2']) .verdict-line {
    transform: scaleX(1);
    transition: transform 520ms cubic-bezier(0.16, 1, 0.3, 1) 120ms;
  }

  :global(.journey-workbench[data-active-step='2']) .annotation-card {
    opacity: 1;
    transform: translateX(0);
    transition:
      opacity 320ms ease 180ms,
      transform 420ms cubic-bezier(0.16, 1, 0.3, 1) 180ms;
  }

  :global(.journey-workbench[data-active-step='2']) .annotation-card-delay {
    transition-delay: 280ms;
  }

  .apply-state-compact .verdict-line {
    transform: scaleX(1);
  }

  .apply-state-compact .annotation-card {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .verdict-line,
    .annotation-card {
      opacity: 1;
      transform: none;
      transition: none !important;
    }
  }
</style>
