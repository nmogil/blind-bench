---
// DashboardPreview: static mockup of the engineer's CyclesList / CycleDetail
// view. Non-interactive — purely illustrative. Copy and structure mirror the
// real app (src/routes/orgs/projects/cycles/*).

const tabs = [
  { label: 'Editor', active: false },
  { label: 'Run', active: false },
  { label: 'Evaluate', active: true },
  { label: 'History', active: false },
  { label: 'Settings', active: false },
];

const outputs = [
  {
    label: 'A',
    model: 'Claude Sonnet 4.5',
    excerpt:
      'I\u2019m really sorry about the double charge \u2014 that\u2019s on us. I\u2019ve refunded the duplicate $49; you\u2019ll see it in 3\u20135 business days.',
    comments: 4,
  },
  {
    label: 'B',
    model: 'GPT-4o',
    excerpt:
      'Thank you for reaching out. I can confirm a duplicate charge of $49.00 was processed in error and have initiated a full refund.',
    comments: 6,
  },
  {
    label: 'C',
    model: 'Gemini 2.5 Pro',
    excerpt:
      'Apologies for the inconvenience. I\u2019ve looked into your account and reversed the second $49 charge.',
    comments: 3,
  },
];
---

<div class="reveal-scale mx-auto mt-14 max-w-4xl">
  <div
    class="overflow-hidden rounded-2xl border border-border/80 bg-card shadow-2xl ring-1 ring-foreground/5 dark:border-border"
  >
    <!-- Window chrome -->
    <div class="flex items-center gap-2 border-b border-border px-4 py-3">
      <div class="flex gap-1.5" aria-hidden="true">
        <div class="h-2.5 w-2.5 rounded-full bg-border"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-border"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-border"></div>
      </div>
      <div class="ml-4 flex-1">
        <div
          class="mx-auto w-fit rounded-md bg-muted px-3 py-1 text-xs text-muted-foreground"
        >
          support-bot &middot; Review cycles
        </div>
      </div>
    </div>

    <!-- Tab strip -->
    <div
      class="flex items-center gap-5 border-b border-border px-5 text-xs"
      aria-hidden="true"
    >
      {
        tabs.map((t) => (
          <span
            class={
              t.active
                ? '-mb-px border-b-2 border-primary py-2.5 font-medium text-foreground'
                : 'py-2.5 text-muted-foreground'
            }
          >
            {t.label}
          </span>
        ))
      }
    </div>

    <!-- Cycle header row -->
    <div class="border-b border-border px-5 py-4">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <h3 class="text-sm font-semibold text-foreground">
            v3 vs v2 comparison
          </h3>
          <span
            class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-2 py-0.5 text-[10px] font-medium text-primary"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-primary" aria-hidden="true"></span>
            Open
          </span>
        </div>
        <div class="flex items-center gap-3 text-xs text-muted-foreground">
          <span>14 / 15 evaluators</span>
          <span aria-hidden="true">&middot;</span>
          <span>152 outputs</span>
        </div>
      </div>
      <!-- Progress bar -->
      <div
        class="mt-3 h-1 w-full overflow-hidden rounded-full bg-muted"
        aria-hidden="true"
      >
        <div class="h-full rounded-full bg-primary" style="width: 93%"></div>
      </div>
    </div>

    <!-- Output cards -->
    <div
      class="grid grid-cols-1 divide-y divide-border sm:grid-cols-3 sm:divide-x sm:divide-y-0"
    >
      {
        outputs.map((o) => (
          <div class="p-4">
            <div class="flex items-center gap-2">
              <span class="inline-flex h-5 w-5 items-center justify-center rounded bg-muted text-[10px] font-semibold text-foreground">
                {o.label}
              </span>
              <span class="truncate text-xs text-muted-foreground">
                {o.model}
              </span>
            </div>
            <p class="mt-2.5 line-clamp-2 text-xs leading-relaxed text-foreground/70">
              {o.excerpt}
            </p>
            <div class="mt-3 flex items-center gap-1.5 text-[11px] text-muted-foreground">
              <svg
                class="h-3 w-3"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
              </svg>
              <span>{o.comments} comments</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
