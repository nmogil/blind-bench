---
import StepCard from './StepCard.astro';
import ArrowRight from '../icons/ArrowRight.astro';
import Pencil from '../icons/Pencil.astro';
import Play from '../icons/Play.astro';
import EyeOff from '../icons/EyeOff.astro';
import Sparkles from '../icons/Sparkles.astro';

// Step colors use CSS custom properties for theme-aware differentiation.
const steps = [
  {
    number: 1,
    title: 'Create',
    description:
      'Write your prompt with variables and test cases that cover real scenarios.',
    Icon: Pencil,
    color: 'var(--step-1)',
  },
  {
    number: 2,
    title: 'Run',
    description:
      'Execute against multiple models simultaneously — A/B/C fan-out in one click.',
    Icon: Play,
    color: 'var(--step-2)',
  },
  {
    number: 3,
    title: 'Evaluate blind',
    description:
      'Reviewers see outputs labeled A, B, C — never which version or model wrote them.',
    Icon: EyeOff,
    color: 'var(--step-3)',
  },
  {
    number: 4,
    title: 'Optimize',
    description:
      'AI reads your annotations and rewrites the prompt, citing specific feedback.',
    Icon: Sparkles,
    color: 'var(--step-4)',
  },
];
---

<section id="how-it-works" class="py-16 lg:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
        How it works
      </h2>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
        From first draft to optimized prompt in four steps.
      </p>
    </div>

    <div class="relative mt-16">
      <!-- Connector line (desktop only) -->
      <div
        class="connector-line absolute top-6 right-0 left-0 hidden h-px bg-border lg:block"
        aria-hidden="true"
      >
      </div>

      <div
        class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8"
      >
        {steps.map(({ Icon, ...rest }, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <StepCard {...rest}>
              <Icon slot="icon" class="h-4 w-4" />
            </StepCard>
          </div>
        ))}
      </div>
    </div>

    <div class="reveal mt-12 text-center">
      <a
        href="https://app.blindbench.dev"
        class="inline-flex min-h-11 items-center gap-1.5 rounded-md px-3 py-2.5 text-sm font-medium text-primary transition-colors hover:text-primary/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
      >
        Try the full workflow
        <ArrowRight class="h-3.5 w-3.5" />
      </a>
    </div>
  </div>
</section>
