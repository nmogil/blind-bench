    "dockview-react": "^5.2.0",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "posthog-js": "^1.372.9",
    "posthog-node": "^5.29.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
